# ============================================================
# AI Trading Assistant — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# SAFETY: All dangerous flags default to false.
# ============================================================

# ── Alpaca API Credentials ───────────────────────────────────
# Leave blank to use MockBroker (no real trades, no keys needed)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── SAFETY LOCKS (READ CAREFULLY BEFORE CHANGING) ────────────
#
# ENABLE_LIVE_TRADING
#   false (default) = paper trading or mock broker only, no real money
#   true            = REAL MONEY AT RISK — only enable if you accept full risk
#
ENABLE_LIVE_TRADING=false

#
# ENABLE_AUTO_LIVE_TRADING
#   false (default) = live auto-trading is LOCKED (will be blocked even if
#                     ENABLE_LIVE_TRADING=true)
#   true            = allows the system to place LIVE orders automatically
#                     REQUIRES ENABLE_LIVE_TRADING=true as well
#                     *** EXTREME RISK — DO NOT ENABLE UNLESS YOU ARE CERTAIN ***
#
ENABLE_AUTO_LIVE_TRADING=false

#
# ENABLE_AUTO_MODE
#   false (default) = auto paper/mock trading disabled
#   true            = allows auto trading in paper/mock mode only
#
ENABLE_AUTO_MODE=false

# ── Risk Limits ───────────────────────────────────────────────
# All trades are blocked if any of these limits are exceeded.

# Maximum total loss allowed per day (USD). Trading halts when hit.
MAX_DAILY_LOSS=100

# Maximum notional value of a single order (USD)
MAX_POSITION_SIZE=500

# Maximum number of trade orders allowed per calendar day
MAX_TRADES_PER_DAY=5

# Stop-loss: percentage below entry price to trigger auto stop (e.g. 2.0 = 2%)
STOP_LOSS_PCT=2.0

# Take-profit: percentage above entry price to trigger take-profit (e.g. 5.0 = 5%)
TAKE_PROFIT_PCT=5.0

# Mandatory wait time in seconds after a losing trade before new orders are allowed
COOLDOWN_SECONDS=300

# ── Order Safety ─────────────────────────────────────────────
# Reject a duplicate order (same ticker + side) within this window (seconds)
REJECT_DUPLICATE_ORDERS=true
DUPLICATE_ORDER_WINDOW_SECONDS=60

# Block orders when market is closed (applies to live mode)
REJECT_MARKET_CLOSED=true

# ── Day Trading Agent (scales with account equity) ────────────────────
DAY_TRADE_DAILY_TARGET_PCT=0.75
DAY_TRADE_DAILY_TARGET_USD=0
DAY_TRADE_MAX_LOSS_PCT=1.5
DAY_TRADE_RISK_PER_TRADE_PCT=0.75
DAY_TRADE_MAX_OPEN_POSITIONS=3
DAY_TRADE_MIN_SCORE=68
DAY_TRADE_RISK_REWARD=2.0
DAY_TRADE_FLAT_BEFORE_CLOSE_MIN=15

# ── AI Analysis (OpenAI preferred) ────────────────────────────────────────────
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional Gemini fallback: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# auto = Gemini first, then OpenAI | gemini (default) | openai
AI_PROVIDER=gemini
# Scan table batch notes
AI_SCAN_PROVIDER=gemini
AI_SCAN_TOP_N=20
# Per-stock AI Summary, ticker chat, research notes — ChatGPT
AI_STOCK_PROVIDER=openai
AI_DEEP_PROVIDER=openai

# ── Database (required on Railway for persistent scan cache) ───────────────
# Local dev:
DATABASE_URL=sqlite:///trading.db
#
# Railway — link Postgres to your app service, then set:
# DATABASE_URL=${{Postgres.DATABASE_URL}}
#
# Or paste the public URL from Railway Postgres → Connect:
# DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway
#
# What Postgres stores:
#   - Paper trades, logs, proposals (permanent until you delete)
#   - Scan cache for Strategy Signals / US Market (full refresh every SCAN_CACHE_REFRESH_MINUTES)

# ── Scan cache refresh ───────────────────────────────────────────────────
# Full re-scan overwrites cached results (not a partial patch). Default 5 min.
SCAN_CACHE_REFRESH_MINUTES=5
# UI checks for new cache this often (seconds). Default 30.
SCAN_UI_POLL_SECONDS=30

# ── Approval Workflow ─────────────────────────────────────────────────────
# ENABLE_APPROVAL_REQUIRED_LIVE_MODE
#   false (default) = no approval gate for live orders (NOT recommended)
#   true            = EVERY live order must be manually approved before execution
#
ENABLE_APPROVAL_REQUIRED_LIVE_MODE=false

# Trade proposals auto-expire after this many minutes (default: 5)
APPROVAL_EXPIRY_MINUTES=5

# If the current price drifts more than this % from estimated price after approval,
# re-approval is required before the order executes (default: 0.5%)
MAX_PRICE_DRIFT_AFTER_APPROVAL_PERCENT=0.5

# ── Portfolio Risk Controls ───────────────────────────────────────────────
# Maximum allocation as % of total portfolio value for a single ticker (default: 20%)
MAX_PORTFOLIO_ALLOCATION_PER_TICKER_PERCENT=20

# Maximum % of account equity risked per single trade (used by position sizer, default: 1%)
MAX_RISK_PER_TRADE_PERCENT=1

# ── Live Order Safety Controls ────────────────────────────────────────────
# Block live order if bid/ask spread exceeds this % (default: 0.5%)
MAX_SPREAD_PERCENT=0.5

# Block new trades within this many minutes before market close (default: 15)
BLOCK_TRADES_NEAR_MARKET_CLOSE_MINUTES=15

# If false (default), live orders use LIMIT orders. Set true to allow MARKET orders live.
ALLOW_MARKET_ORDERS_LIVE=false
